{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"target": "ES2020",
		"useDefineForClassFields": true,
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"jsx": "react",

		"declarationDir": "./dist/types"
	},
	"include": ["src"],
	"exclude": ["node_modules"]
}
