{
	"name": "@paperless/react",
	"sideEffects": false,
	"version": "3.15.5",
	"description": "React specific wrapper for component-library",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Employes/Paperless.git"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org"
	},
	"scripts": {
		"prebuild": "yarn",
		"build": "yarn clean && yarn compile",
		"build:prod": "yarn build",
		"clean": "rm -rf dist",
		"compile": "yarn tsc",
		"tsc": "tsc -p . --outDir ./dist",
		"rollup": "rollup -c",
		"prenpm:publish": "cp ../../README.md .",
		"npm:publish": "npm publish",
		"npm:publish:prerelease": "yarn npm:publish --tag alpha",
		"prettier:check": "yarn prettier \"./src/**/*.{ts,tsx,html,scss,json}\"",
		"prettier:write": "yarn prettier:check -w"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/components.js",
			"type": "./dist/types/components.d.ts"
		},
		"./vite": {
			"import": "./dist/vite.js",
			"type": "./dist/types/vite.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@paperless/core": "^3.15.5",
		"@stencil/react-output-target": "~1.2.1",
		"@stencil/ssr": "~0.3.1"
	},
	"devDependencies": {
		"@types/node": "~25.0.9",
		"@types/react": "~19.2.8",
		"react": "~19.2.3",
		"react-dom": "~19.2.3",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"jest": {
		"preset": "ts-jest",
		"setupTestFrameworkScriptFile": "<rootDir>/jest.setup.js",
		"testPathIgnorePatterns": [
			"node_modules",
			"dist"
		]
	}
}
